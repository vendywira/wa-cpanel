# WhatsApp API Security Configuration
# Salin file ini ke .env dan isi dengan nilai Anda

# API Key untuk mengakses API endpoints
# Generate dengan: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
WA_API_KEY=your-secret-api-key-change-this-2026

# Session Secret untuk cookie encryption
# Generate dengan: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
WA_SESSION_SECRET=session-secret-change-this-2026

# Admin credentials
ADMIN_USERNAME=admin
ADMIN_PASSWORD_HASH=$2b$10$...  # Generate dengan script di bawah
ADMIN_NAME=Administrator

# Port untuk server (optional)
PORT=3000
